#!/usr/bin/env bash
set -euo pipefail

selection=$(rg -n --color=always "." | \
  fzf --ansi \
      --delimiter ':' \
      --preview 'bat --color=always --highlight-line {2} -- {1}' \
      --preview-window 'up,60%,+{2}-10')

file=$(echo "$selection" | cut -d: -f1)
line=$(echo "$selection" | cut -d: -f2)

nvim "+${line}" "${file}"
